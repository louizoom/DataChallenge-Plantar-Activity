# ==============================================================
# Plantar Activity Classification — Environment Configuration
# ==============================================================
# Copy this file to `.env` and fill in your local paths.
# The `.env` file is git-ignored and must never be committed.
# ==============================================================

# Absolute or relative (to project root) path to the data root directory.
# This folder must contain PLANTAR_FOLDER and EVENTS_FOLDER as sub-directories.
DATA_ROOT=DataChallenge_donneesGlobales

# Name of the insoles sub-folder inside DATA_ROOT.
# Use the sorted variant:   Plantar_activity_trie
# Use the unsorted variant: Plantar_activity
PLANTAR_FOLDER=Plantar_activity_trie

# Name of the classification annotations sub-folder inside DATA_ROOT.
EVENTS_FOLDER=Events
